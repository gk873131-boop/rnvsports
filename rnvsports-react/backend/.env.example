# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=salvaind_rnvsports

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d

# CORS
CLIENT_URL=http://localhost:5173

# File uploads
BASE_URL=http://localhost:5000
UPLOAD_DIR=uploads

# PhonePe Payment Gateway
PHONEPE_MERCHANT_ID=M1RDSSZWZBWY
PHONEPE_SALT_KEY=your_phonepe_salt_key_here
PHONEPE_SALT_INDEX=1
PHONEPE_API_URL=https://api.phonepe.com/apis/hermes/pg/v1/pay
PHONEPE_CALLBACK_URL=https://yourdomain.com/api/payment/callback

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
